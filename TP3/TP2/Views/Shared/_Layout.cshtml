<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TP2</title> <!-- Peut être pas défini-->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    

    <!-- Bootstrap -->
    
    <!-- Fontawsome -->
    <script src="https://kit.fontawesome.com/f6759a0638.js" crossorigin="anonymous"></script>
    
    <!-- Mon Css -->
    <link rel="stylesheet" href="/css/PAGE_CARTE.css">
    <link rel="stylesheet" href="/css/Décore.css">
    <link rel="stylesheet" href="/css/Menu.css">


    @* @RenderSection("CSS", false) *@
</head>
<body>
    <Header>
        <div class="text-center">
            <h1 id="NomSite" class="w-100">CHOIX</h1>
            <a href="~/Home/Index"><i class="fa-solid fa-house" id="Home"></i></a>
            <a href="~/Enfant/favoris"><i class="fa-regular fa-star" id="SelectFavorie"></i></a>
            <a href="~/Enfant/Recherche"><i class="fa-solid fa-magnifying-glass" id="Selection_Recherche"></i></a>
        </div>
    </Header>
    <main class="container">
        <div class="row">

            <div class="col pt-3 " id="ContenuDuRenderBody">
                @RenderBody()
            </div>

        </div>
    </main>
    <footer class="contaner w-100 h-10">
        <p> NVIDIA|AMD|INTEL</p>
        <p> Site Web</p>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p" crossorigin="anonymous"></script>
</body>