@using TP2.Models
@model List<Compagnie>
@{
    Layout = "_Layout";
    ViewData["style"] = "Compagnie";
    
}

<div class="row bg-opacity-75 opacity-5 BuleSélection" id="options">
    @foreach (Compagnie item in Model)
    {
        <div class="col-md-4 align-content-center @(item.Nom) Box ">
            <a href="~/Enfant/Recherche">
                <img src="@item.imgURL"
                     alt="@item.Nom" class="img-fluid">
            </a>
            <p class="Texte_Blanc">
                @item.Description

            </p>
            
            <p class="d-inline-block fw-bold" style="color: white;">
                <br />
                

                Nb Cartes:
                @item.Cartes_Graphiques.Count
                
            </p>
            

        </div>

    }
    
    
</div>

