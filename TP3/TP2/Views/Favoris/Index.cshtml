@using TP2.Models
@using TP2.ViewModels

@model List<TP2.Models.Carte_Graphique>

@{
    ViewData["style"] = "Favoris";
}

<section class="container my-5">
    <h1 class="mb-4 text-center">Vos choix :</h1>

    <!-- Nombre de favoris -->
    <p class="fs-5 mb-4">
        Vous avez <strong>@Model.Count</strong> éléments en favoris !
    </p>

    <!-- Tableau -->
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Image</th>
                    <th>Carte</th>
                    <th>Compagnie</th>
                    <th>Retirer</th>
                </tr>
            </thead>

            <tbody>
                <p>Cette zone n'est pas demandée dans le TP2 donc je ne savais pas si je devait la faire</p>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@item.imgURL" alt="@item.Model" class="img-fluid"
                                 style="max-width: 80px;">
                        </td>

                        <td>
                            <a href="~/Enfant/Detail/@(item.ID)" class="text-decoration-none fw-bold">
                                @(item.Nom)
                            </a>
                        </td>

                        <td>@(item.compagnie.Nom)</td>

                        <td>
                            <form asp-controller="Favoris" asp-action="SupprimerUnEnfant" method="post">
                                <input type="hidden" name="id" value="@item.ID" />
                                <button type="submit" class="btn btn-danger">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>

                            
                        </td>
                    </tr>
                }



            </tbody>
        </table>
    </div>
</section>

